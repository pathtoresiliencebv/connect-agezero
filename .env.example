# Agezero Connect — environment variables
# Copy to .env.local for local dev, and to your Vercel project for prod.

# NextAuth — REQUIRED
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Nango (optional) — enables the live Connect flow + proxy
NEXT_PUBLIC_NANGO_PUBLIC_KEY=
NANGO_SECRET_KEY=
# NANGO_API_BASE=https://api.nango.dev
NEXT_PUBLIC_NANGO_DEFAULT_CONNECTION_ID=demo-user

# Default seed user (the demo login shown on the login page).
# Easiest: use PLAIN, hashed on first boot and persisted to data/users.json.
SEED_USER_EMAIL=demo@agezero.app
SEED_USER_NAME=Demo User
SEED_USER_PASSWORD_PLAIN=demo
# Advanced: pre-baked bcrypt hash. Escapes required: \$2a\$10\$...
# SEED_USER_PASSWORD_HASH=\$2a\$10\$REPLACE_ME